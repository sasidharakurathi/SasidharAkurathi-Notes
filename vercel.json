{
  "buildCommand": "python build.py",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/docker_chapter_:slug",
      "destination": "/docker/chapter_:slug"
    },
    {
      "source": "/docker_chapter_:slug.html",
      "destination": "/docker/chapter_:slug"
    },
    {
      "source": "/chapter_:slug",
      "destination": "/fastapi/chapter_:slug"
    },
    {
      "source": "/chapter_:slug.html",
      "destination": "/fastapi/chapter_:slug"
    },
    {
      "source": "/n8n_chapter_:slug",
      "destination": "/n8n/chapter_:slug"
    },
    {
      "source": "/n8n_chapter_:slug.html",
      "destination": "/n8n/chapter_:slug"
    }
  ]
}