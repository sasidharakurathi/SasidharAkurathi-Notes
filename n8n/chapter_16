    <h3>The INodeType Interface Anatomy</h3>
    <p>Every node we build must implement the <code>INodeType</code> interface. This class does two things: it defines
        the <strong>UI properties</strong> (what the node looks like, what inputs it requires), and it defines the
        <strong>Execute function</strong> (what the node actually does).</p>

    <p>The <code>description</code> object dictates the frontend UI:</p>

    <pre><code class="language-typescript">// nodes/MyApi/MyApi.node.ts
import { INodeType, INodeTypeDescription } from 'n8n-workflow';

export class MyApi implements INodeType {
    description: INodeTypeDescription = {
        displayName: 'My Internal API',
        name: 'myApi',
        icon: 'file:myApi.svg', // Local SVG file for the node icon
        group: ['transform'],
        version: 1,
        description: 'Consume our internal microservices',
        defaults: {
            name: 'My Internal API',
        },
        inputs: ['main'],
        outputs: ['main'],
        credentials: [
            {
                name: 'myApiApi',
                required: true,
            },
        ],
        // The properties array defines the actual form fields in the UI
        properties: [
            {
                displayName: 'Operation',
                name: 'operation',
                type: 'options',
                noDataExpression: true,
                options: [
                    {
                        name: 'Get User',
                        value: 'getUser',
                    },
                    {
                        name: 'Create User',
                        value: 'createUser',
                    },
                ],
                default: 'getUser',
            },
            {
                displayName: 'User ID',
                name: 'userId',
                type: 'string',
                required: true,
                displayOptions: {
                    show: {
                        operation: ['getUser'], // Only shows if operation == 'getUser'
                    },
                },
                default: '',
            }
        ],
    };
    
    // The execute function runs when the node actually fires
    async execute(this: IExecuteFunctions): Promise&lt;INodeExecutionData[][]&gt; {
        // Implementation logic here...
    }
}</code></pre>

